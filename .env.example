# Optional: NCBI API key for higher PubMed rate limits
# NCBI_API_KEY=your_key_here

# Optional: Semantic Scholar API key
# S2_API_KEY=your_key_here

# LLM backend selection: "claude" (default), "codex", "openai", or "openrouter"
#
# Recommended public-demo options:
# - claude: run `claude login`, then use the local Claude CLI
# - codex: run `codex login`, then use Codex / OpenAI OAuth
# BIOCOMPUTE_LLM_BACKEND=claude
# BIOCOMPUTE_LLM_BACKEND=codex

# Alternative: required when using openai backend (official OpenAI API key)
# OPENAI_API_KEY=your_key_here

# Alternative: required when using openrouter backend
# OPENROUTER_API_KEY=your_key_here
# OPENROUTER_SITE_URL=https://your-site.example
# OPENROUTER_APP_NAME=BioCompute
